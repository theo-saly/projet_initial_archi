{
    "name": "project-service",
    "version": "1.0.0",
    "main": "src/index.ts",
    "license": "MIT",
    "scripts": {
        "dev": "nodemon -L --exec ts-node src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "migrate:up": "ts-node src/migrations/cli.ts up",
        "migrate:down": "ts-node src/migrations/cli.ts down",
        "migrate:up:prod": "node dist/migrations/cli.js up",
        "migrate:down:prod": "node dist/migrations/cli.js down",
        "test": "jest"
    },
    "dependencies": {
        "express": "^5.2.1",
        "sqlite3": "^5.1.7",
        "uuid": "^13.0.0",
        "jsonwebtoken": "^9.0.3",
        "ioredis": "^5.6.1",
        "mysql2": "^3.17.4"
    },
    "devDependencies": {
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^25.9.2",
        "@types/uuid": "^10.0.0",
        "@types/jest": "^30.0.0",
        "jest": "^30.2.0",
        "nodemon": "^3.1.14",
        "ts-jest": "^29.4.11",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.3"
    }
}
